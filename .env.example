# .env.example — copy to .env and customize
# CLIProxyAPI 地址（支持完整 URL，会自动解析协议、主机、端口）
CLIPROXY_URL=http://127.0.0.1:8317
# 兼容旧写法（CLIPROXY_URL 未设置时使用）：
# CLIPROXY_HOST=127.0.0.1
# CLIPROXY_PORT=8317

# CLIProxyAPI 管理密码
MANAGEMENT_KEY=your-management-key-here
# 数据库保存地址
DB_PATH=./data/usage.sqlite
# 账户json保存目录
AUTH_DIR=./auths
# 轮询获取 CLIProxyAPI 用量间隔 秒
POLL_INTERVAL_SECONDS=2
# 账户获取用量信息间隔 秒
QUOTA_REFRESH_SECONDS=300
# 代理地址
SOCKS5_PROXY_HOST=
# 代理端口
SOCKS5_PROXY_PORT=0

# Dashboard 登录密钥（不设置则跳过认证）
ACCESS_KEY=admin123